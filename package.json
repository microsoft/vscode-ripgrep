{
  "name": "vscode-ripgrep-monorepo",
  "version": "1.18.0",
  "private": true,
  "description": "Monorepo for @vscode/ripgrep and its per-platform binary packages.",
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/vscode-ripgrep"
  },
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "sync-packages": "node ./build/sync-packages.js",
    "prepare-binaries": "node ./build/prepare-binaries.js",
    "update-lock": "node ./build/prepare-binaries.js --update-lock"
  },
  "devDependencies": {
    "@types/node": "^20.8.4"
  }
}

